{
  "env": {
    "CLAUDE_AUTOCOMPACT_PCT_OVERRIDE": "70"
  },
  "permissions": {
    "allow": [
      "Bash(gh pr view*)",
      "Bash(gh pr diff*)",
      "Write(~/Documents/claude-scratch/*)",
      "Edit(~/Documents/claude-scratch/*)",
      "Read(~/Documents/claude-refs/*)",
      "Bash(python -m py_compile:*)",
      "Bash(python3 -m py_compile:*)",
      "Bash(echo \"OK: compiles\")",
      "Bash(grep:*)",
      "Bash(echo:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(wc:*)",
      "Bash(sort:*)",
      "Bash(cut:*)",
      "Bash(find:*)",
      "Bash(cat:*)",
      "Bash(ls:*)",
      "Bash(git merge-base:*)",
      "Bash(git diff:*)",
      "Bash(git fetch:*)",
      "Bash(git show:*)",
      "Bash(git log:*)",
      "WebFetch(domain:github.com)"
    ],
    "defaultMode": "default"
  },
  "model": "opus",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "notify-send 'claude code tooling' \"$(jq -r '.tool_input.command // \"unknown\"' | head -c 150)\" --icon=utilities-terminal --urgency=low",
            "async": true
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "notify-send 'Claude Code' 'permission required' --icon=dialog-question --urgency=normal",
            "async": true
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "notify-send 'Claude Code' 'ready or requires more input' --icon=dialog-information --urgency=normal",
            "async": true
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "typescript-lsp@claude-plugins-official": true,
    "pyright-lsp@claude-plugins-official": true,
    "gopls-lsp@claude-plugins-official": true,
    "rust-analyzer-lsp@claude-plugins-official": true,
    "clangd-lsp@claude-plugins-official": true,
    "lua-lsp@claude-plugins-official": true
  },
  "effortLevel": "high",
  "verbose": true,
  "remoteControlAtStartup": false,
  "tui": "fullscreen"
}
